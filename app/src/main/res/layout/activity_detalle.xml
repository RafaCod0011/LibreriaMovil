<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#84E297"
    tools:context=".DetalleActivity">

    <ImageView
        android:id="@+id/imgPortada"
        android:layout_width="160dp"
        android:layout_height="250dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/cien_anos_de_soledad" />

    <TextView
        android:id="@+id/lblTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="TÍTULO"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#4E5D4E"
        android:paddingStart="12dp"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toEndOf="@id/imgPortada"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:maxLines="3"
        android:ellipsize="end"
        android:paddingStart="12dp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toEndOf="@id/imgPortada"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lblTitulo"/>

    <TextView
        android:id="@+id/lblAutor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="AUTOR"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#4E5D4E"
        android:paddingStart="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toEndOf="@id/imgPortada"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"/>

    <TextView
        android:id="@+id/tvAutor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#000000"
        android:paddingStart="12dp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toEndOf="@id/imgPortada"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lblAutor"/>

    <TextView
        android:id="@+id/lblPaginas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PÁGINAS"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#4E5D4E"
        android:paddingStart="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toEndOf="@id/imgPortada"
        app:layout_constraintTop_toBottomOf="@id/tvAutor"/>

    <TextView
        android:id="@+id/tvPaginas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#000000"
        android:paddingStart="12dp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toEndOf="@id/imgPortada"
        app:layout_constraintTop_toBottomOf="@id/lblPaginas"/>

    <TextView
        android:id="@+id/lblFecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AÑO"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#4E5D4E"
        android:layout_marginTop="12dp"
        android:layout_marginStart="32dp"
        app:layout_constraintStart_toEndOf="@id/tvPaginas"
        app:layout_constraintTop_toBottomOf="@id/tvAutor"/>

    <TextView
        android:id="@+id/tvFecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#000000"
        android:layout_marginTop="4dp"
        android:layout_marginStart="32dp"
        app:layout_constraintStart_toEndOf="@id/tvPaginas"
        app:layout_constraintTop_toBottomOf="@id/lblFecha"/>

    <TextView
        android:id="@+id/lblGeneros"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GÉNERO/S"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#4E5D4E"
        android:layout_marginTop="24dp"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toBottomOf="@id/imgPortada"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGeneros"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="@android:color/transparent"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/lblGeneros"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_generos"
        tools:itemCount="6"
        tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        tools:spanCount="3"/>

    <TextView
        android:id="@+id/lblSinopsis"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SINOPSIS"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#4E5D4E"
        android:layout_marginTop="16dp"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toBottomOf="@id/rvGeneros"
        app:layout_constraintStart_toStartOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:padding="8dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/lblSinopsis"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#D8F0B8"
            android:padding="20dp"
            android:textColor="#000000"
            android:textSize="16sp"
            android:lineSpacingExtra="3dp" />

    </ScrollView>

    <TextView
        android:id="@+id/btVolver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:text="← Volver"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>